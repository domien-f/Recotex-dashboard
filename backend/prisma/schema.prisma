generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum DealStatus {
  NEW
  QUALIFIED
  APPOINTMENT
  WON
  LOST
}

enum AppointmentOutcome {
  PENDING
  WON
  LOST
  CANCELLED
}

enum CostType {
  AD_SPEND
  INVOICE
  MANUAL
}

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
}

enum InvoiceStatus {
  PENDING
  PARSED
  CONFIRMED
  ERROR
}

enum KpiPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         Role      @default(VIEWER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions     Session[]
  invoices     Invoice[]  @relation("UploadedBy")
  kpiTargets   KpiTarget[]
  integrations IntegrationCredential[]
  aiConversations AiConversation[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Contact {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?
  name      String?
  street    String?
  postcode  String?
  city      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deals Deal[]

  @@index([email])
  @@map("contacts")
}

model Deal {
  id                String     @id @default(cuid())
  contactId         String     @map("contact_id")
  title             String?
  phase             String?
  status            DealStatus @default(NEW)
  herkomst          String?
  typeWerken        String?    @map("type_werken")
  reclamatieRedenen String[]   @map("reclamatie_redenen")
  verantwoordelijke String?
  revenue           Decimal?   @db.Decimal(12, 2)
  probability       Float      @default(0)
  wonAt             DateTime?  @map("won_at")
  dealCreatedAt     DateTime?  @map("deal_created_at")
  teamleaderId      String?    @unique @map("teamleader_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([herkomst])
  @@index([status])
  @@index([dealCreatedAt])
  @@index([contactId])
  @@map("deals")
}

model Appointment {
  id           String             @id @default(cuid())
  dealId       String             @map("deal_id")
  date         DateTime                                          // wanneer de afspraak doorgaat (starts_at)
  scheduledAt  DateTime?          @map("scheduled_at")           // wanneer de afspraak gepland werd
  cost         Decimal?           @db.Decimal(12, 2)
  outcome      AppointmentOutcome @default(PENDING)
  channel      String?
  notes        String?
  teamleaderId String?            @unique @map("teamleader_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([channel])
  @@index([outcome])
  @@index([date])
  @@map("appointments")
}

model Cost {
  id                 String   @id @default(cuid())
  channel            String
  amount             Decimal  @db.Decimal(12, 2)
  date               DateTime
  type               CostType
  description        String?
  invoiceId          String?  @map("invoice_id")
  isEstimated        Boolean  @default(false) @map("is_estimated")
  estimatedFromMonth DateTime? @map("estimated_from_month")
  source             String?    // meta_api, solvari_csv, solvari_api, invoice_ai, manual
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([channel])
  @@index([date])
  @@index([type])
  @@index([isEstimated])
  @@index([source])
  @@map("costs")
}

model Invoice {
  id          String        @id @default(cuid())
  filename    String
  filePath    String        @map("file_path")
  uploadedBy  String        @map("uploaded_by")
  parsedData  Json?         @map("parsed_data")
  totalAmount Decimal?      @db.Decimal(12, 2) @map("total_amount")
  vendor      String?
  channel     String?
  date        DateTime?
  status      InvoiceStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")

  uploader User   @relation("UploadedBy", fields: [uploadedBy], references: [id])
  costs    Cost[]

  @@index([vendor])
  @@index([status])
  @@map("invoices")
}

model AdPlatformData {
  id           String     @id @default(cuid())
  platform     AdPlatform
  campaignId   String     @map("campaign_id")
  campaignName String?    @map("campaign_name")
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  spend        Decimal    @db.Decimal(12, 2) @default(0)
  leads        Int        @default(0)
  date         DateTime
  rawData      Json?      @map("raw_data")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([platform, campaignId, date])
  @@index([platform])
  @@index([date])
  @@map("ad_platform_data")
}

model KpiTarget {
  id          String    @id @default(cuid())
  category    String
  metric      String
  targetValue Decimal   @db.Decimal(12, 4) @map("target_value")
  channel     String?
  month       DateTime? @db.Date
  period      KpiPeriod @default(MONTHLY)
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@unique([metric, month], name: "metric_month")
  @@index([category])
  @@index([metric])
  @@map("kpi_targets")
}

model IntegrationCredential {
  id           String   @id @default(cuid())
  platform     String   @unique // teamleader, meta, google, tiktok
  accessToken  String   @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  extra        Json?    // any extra config (account IDs, etc.)
  connectedBy  String   @map("connected_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [connectedBy], references: [id])

  @@map("integration_credentials")
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_conversations")
}

model SyncLog {
  id            String     @id @default(cuid())
  source        String
  status        SyncStatus
  recordsSynced Int        @default(0) @map("records_synced")
  error         String?
  startedAt     DateTime   @default(now()) @map("started_at")
  completedAt   DateTime?  @map("completed_at")

  @@index([source])
  @@index([startedAt])
  @@map("sync_logs")
}
